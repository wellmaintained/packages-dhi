#!/usr/bin/env bash
# Generate .env with digest-pinned stock image references from image-manifest.json
#
# Output: apps/sbomify/deployments/.env.stock-images
# Used by docker-compose.yml via variable substitution
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
MANIFEST="${REPO_ROOT}/.github/image-manifest.json"
ENV_FILE="${REPO_ROOT}/apps/sbomify/deployments/.env.stock-images"

echo "Generating stock image .env from manifest..."

{
    echo "# Auto-generated from .github/image-manifest.json"
    echo "# Do not edit manually — run: just render-compose"
    echo ""
    jq -r '.stock[] | select(.digest != "") |
        "STOCK_\(.name | ascii_upcase)_IMAGE=\(.source)@\(.digest)"' "$MANIFEST"
} > "$ENV_FILE"

echo "Written to ${ENV_FILE}"
cat "$ENV_FILE"
