#!/usr/bin/env bash
# Assemble compliance pack ZIP from build artifacts.
set -euo pipefail

VERSION="${1:?Usage: build-compliance-pack <version>}"

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ARTIFACTS="${REPO_ROOT}/artifacts"
TOOL_LOCK="${REPO_ROOT}/common/tool-versions.lock.yaml"
APP_LOCK="${REPO_ROOT}/apps/sbomify/app-images.lock.yaml"
PACK_DIR="${REPO_ROOT}/.compliance-pack"
OUTPUT="${REPO_ROOT}/compliance-pack-${VERSION}.zip"

rm -rf "$PACK_DIR"
mkdir -p "$PACK_DIR"/{sboms,vex,provenance,secrets}

# Copy manifests
cp "$TOOL_LOCK" "$PACK_DIR/tool-versions.lock.yaml"
cp "$APP_LOCK" "$PACK_DIR/app-images.lock.yaml"

# Copy artifacts for each image
for dir in "${ARTIFACTS}"/*/; do
    name=$(basename "$dir")

    [ -f "${dir}sbom.cdx.json" ] && [ -s "${dir}sbom.cdx.json" ] && \
        cp "${dir}sbom.cdx.json" "$PACK_DIR/sboms/${name}.cdx.json"
    [ -f "${dir}sbom.spdx.json" ] && [ -s "${dir}sbom.spdx.json" ] && \
        cp "${dir}sbom.spdx.json" "$PACK_DIR/sboms/${name}.spdx.json"
    [ -f "${dir}provenance.slsa.json" ] && [ -s "${dir}provenance.slsa.json" ] && \
        cp "${dir}provenance.slsa.json" "$PACK_DIR/provenance/${name}.slsa.json"
    # CVE scan output is deliberately excluded — a point-in-time grype snapshot
    # goes stale immediately. Consumers re-scan the shipped SBOM + VEX locally
    # with `grype sbom:<file> --vex <vex>` for the current view.
    [ -f "${dir}secrets.json" ] && [ -s "${dir}secrets.json" ] && \
        cp "${dir}secrets.json" "$PACK_DIR/secrets/${name}.secrets.json"

    # VEX — prefer DHI vendor OpenVEX (vex.dhi.json) over hand-authored
    # vex.json. Mirrors _vex_source() in scripts/extract-release-data, so
    # the compliance pack and the release-website matrix agree on which
    # VEX document we publish for each image. (The two scripts pre-PR
    # never collided because their destinations differed by extension;
    # they share .vex.json now, hence the explicit gate.)
    if [ -f "${dir}vex.dhi.json" ] && [ -s "${dir}vex.dhi.json" ]; then
        cp "${dir}vex.dhi.json" "$PACK_DIR/vex/${name}.vex.json"
    elif [ -f "${dir}vex.json" ] && [ -s "${dir}vex.json" ]; then
        cp "${dir}vex.json" "$PACK_DIR/vex/${name}.vex.json"
    fi
done

# Copy docker-compose for deployment reference
[ -f "${REPO_ROOT}/apps/sbomify/deployments/docker-compose.yml" ] && \
    cp "${REPO_ROOT}/apps/sbomify/deployments/docker-compose.yml" "$PACK_DIR/"

# Create ZIP
cd "$PACK_DIR"
zip -r "$OUTPUT" .
cd "$REPO_ROOT"
rm -rf "$PACK_DIR"

echo "Compliance pack: ${OUTPUT}"
echo "Contents:"
unzip -l "$OUTPUT" | tail -n +4 | head -n -2
