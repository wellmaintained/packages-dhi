#!/usr/bin/env bash
# Extract attestations (SBOM, VEX, provenance) for all stock DHI images.
# Uses the OCI Referrers API to pull DHI's own attestations — NOT regenerated SBOMs.
# Stores artifacts in .artifacts/<image-name>/ for use by release website and compliance pack.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
APP_LOCK="${REPO_ROOT}/apps/sbomify/app-images.lock.yaml"
ARTIFACTS="${REPO_ROOT}/.artifacts"

mkdir -p "$ARTIFACTS"

# Map of predicate types to output filenames (the ones we care about)
declare -A ATTESTATION_MAP=(
    ["https://cyclonedx.org/bom/v1.6"]="sbom.cdx.json"
    ["https://spdx.dev/Document"]="sbom.spdx.json"
    ["https://slsa.dev/provenance/v1"]="provenance.slsa.json"
    ["https://openvex.dev/ns/v0.2.0"]="vex.dhi.json"
    ["https://in-toto.io/attestation/vulns/v0.2"]="vulns.json"
)

# Extract registry and repo from an image reference like dhi.io/postgres:17
parse_image_ref() {
    local source="$1"
    # Split on first /
    local registry="${source%%/*}"
    local repo_tag="${source#*/}"
    local repo="${repo_tag%%:*}"
    echo "$registry" "$repo"
}

# Get an auth token for a registry/repo
get_token() {
    local registry="$1"
    local repo="$2"
    "${REPO_ROOT}/bin/crane" auth token "${registry}/${repo}" 2>/dev/null \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['token'])"
}

# Resolve the platform-specific manifest digest for linux/amd64
get_platform_digest() {
    local source="$1"
    "${REPO_ROOT}/bin/crane" manifest "$source" 2>/dev/null \
        | python3 -c "
import sys, json
idx = json.load(sys.stdin)
for m in idx.get('manifests', []):
    p = m.get('platform', {})
    if p.get('architecture') == 'amd64' and p.get('os') == 'linux':
        print(m['digest'])
        break
"
}

# Fetch OCI referrers for a given digest
fetch_referrers() {
    local registry="$1"
    local repo="$2"
    local digest="$3"
    local token="$4"
    curl -sS -H "Authorization: Bearer $token" \
        "https://${registry}/v2/${repo}/referrers/${digest}"
}

# Fetch a blob from the registry
fetch_blob() {
    local registry="$1"
    local repo="$2"
    local digest="$3"
    local token="$4"
    curl -sS -H "Authorization: Bearer $token" \
        "https://${registry}/v2/${repo}/blobs/${digest}"
}

# Extract the predicate from an in-toto attestation manifest
extract_attestation() {
    local registry="$1"
    local repo="$2"
    local manifest_digest="$3"
    local token="$4"
    local output_file="$5"

    # Fetch the attestation manifest to get the blob digest
    local att_manifest
    att_manifest=$(curl -sS \
        -H "Authorization: Bearer $token" \
        -H "Accept: application/vnd.oci.image.manifest.v1+json" \
        "https://${registry}/v2/${repo}/manifests/${manifest_digest}")

    local blob_digest
    blob_digest=$(echo "$att_manifest" | python3 -c "
import sys, json
m = json.load(sys.stdin)
layers = m.get('layers', [])
if layers:
    print(layers[0]['digest'])
")

    if [ -z "$blob_digest" ]; then
        echo "      (no blob found)"
        return 1
    fi

    # Fetch the blob and extract the predicate from the in-toto envelope
    fetch_blob "$registry" "$repo" "$blob_digest" "$token" \
        | python3 -c "
import sys, json
envelope = json.load(sys.stdin)
predicate = envelope.get('predicate', {})
json.dump(predicate, sys.stdout, indent=2)
" > "$output_file"

    local size
    size=$(wc -c < "$output_file")
    if [ "$size" -lt 10 ]; then
        rm -f "$output_file"
        echo "      (empty predicate)"
        return 1
    fi
    echo "      saved (${size} bytes)"
}

echo "Extracting DHI attestations for stock images..."
echo ""

for name in $(yq -r 'to_entries[] | select(.value | has("source")) | .key' "$APP_LOCK"); do
    source=$(yq -r ".$name.source" "$APP_LOCK")
    digest=$(yq -r ".$name.digest // \"\"" "$APP_LOCK")

    if [ -z "$digest" ]; then
        echo "  SKIP ${name}: no pinned digest (run 'just update' first)"
        continue
    fi

    out_dir="${ARTIFACTS}/${name}"
    mkdir -p "$out_dir"

    echo "  ${name} (${source}@${digest}):"

    # Parse registry and repo from source
    read -r registry repo <<< "$(parse_image_ref "$source")"

    # Get auth token
    token=$(get_token "$registry" "$repo")

    # Resolve linux/amd64 platform manifest digest from the index
    echo "    Resolving linux/amd64 manifest..."
    platform_digest=$(get_platform_digest "$source")
    if [ -z "$platform_digest" ]; then
        echo "    SKIP: could not resolve amd64 platform digest"
        continue
    fi
    echo "    Platform digest: ${platform_digest}"

    # Fetch OCI referrers for the platform manifest
    echo "    Fetching referrers..."
    referrers=$(fetch_referrers "$registry" "$repo" "$platform_digest" "$token")

    referrer_count=$(echo "$referrers" | python3 -c "import sys,json; print(len(json.load(sys.stdin).get('manifests',[])))")
    echo "    Found ${referrer_count} attestations"

    # Extract each attestation type we care about
    for predicate_type in "${!ATTESTATION_MAP[@]}"; do
        filename="${ATTESTATION_MAP[$predicate_type]}"
        short_type="${predicate_type##*/}"

        # Find the referrer manifest digest for this predicate type
        att_digest=$(echo "$referrers" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for m in data.get('manifests', []):
    ann = m.get('annotations', {})
    if ann.get('in-toto.io/predicate-type') == '${predicate_type}':
        print(m['digest'])
        break
" 2>/dev/null)

        if [ -z "$att_digest" ]; then
            echo "    - ${short_type}: (not found)"
            continue
        fi

        echo "    - ${short_type}:"
        extract_attestation "$registry" "$repo" "$att_digest" "$token" "${out_dir}/${filename}"
    done

    # Run grype scan using the extracted SBOM
    echo "    - CVE scan:"
    if [ -f "${out_dir}/sbom.cdx.json" ]; then
        "${REPO_ROOT}/bin/grype" \
            "sbom:/work/.artifacts/${name}/sbom.cdx.json" -o json \
            > "${out_dir}/cves.json" 2>/dev/null && echo "      saved" || echo "      (scan failed)"
    else
        echo "      (no SBOM available)"
    fi

    echo ""
done

echo "Artifacts written to ${ARTIFACTS}/"
ls -la "${ARTIFACTS}/"
