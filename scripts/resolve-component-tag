#!/usr/bin/env bash
# scripts/resolve-component-tag — Find a component tag by SHA suffix in GHCR.
#
# Usage:
#   scripts/resolve-component-tag --image <name> --sha7 <sha7> --registry <registry>
#
# Prints the resolved component tag to stdout.
# Requires: crane (via bin/crane)
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
  echo "Usage: $0 --image NAME --sha7 SHA7 --registry REGISTRY"
  exit 1
}

IMAGE=""
SHA7=""
REGISTRY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --image) IMAGE="$2"; shift 2 ;;
    --sha7) SHA7="$2"; shift 2 ;;
    --registry) REGISTRY="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$IMAGE" || -z "$SHA7" || -z "$REGISTRY" ]] && usage

# Try crane first (works locally with docker config auth)
COMPONENT_TAG=$("${REPO_ROOT}/bin/crane" ls "${REGISTRY}/${IMAGE}" 2>/dev/null | grep -- "-${SHA7}$" | head -1 || true)

# Fallback to GitHub API for private GHCR packages (works in CI with GH_TOKEN)
if [ -z "$COMPONENT_TAG" ] && [ -n "${GH_TOKEN:-}" ]; then
  # Extract org and image name from registry (e.g. ghcr.io/wellmaintained/hugo → wellmaintained, hugo)
  ORG=$(echo "$REGISTRY" | cut -d/ -f2)
  COMPONENT_TAG=$(gh api "/orgs/${ORG}/packages/container/${IMAGE}/versions" \
    --paginate --jq '.[].metadata.container.tags[]' 2>/dev/null \
    | grep -- "-${SHA7}$" | head -1 || true)
fi

if [ -z "$COMPONENT_TAG" ]; then
  echo "ERROR: No component tag found for ${IMAGE} with SHA ${SHA7}" >&2
  exit 1
fi

echo "==> Component tag: ${COMPONENT_TAG}" >&2
echo "$COMPONENT_TAG"
