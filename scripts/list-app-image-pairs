#!/usr/bin/env bash
# Emit a JSON array of {app, image} pairs across every apps/<app>/app-images.yaml.
# Useful for matrix strategies that walk all apps' custom images.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

pairs="[]"
for d in "${REPO_ROOT}/apps"/*/; do
    manifest="${d}app-images.yaml"
    [[ -f "$manifest" ]] || continue
    app=$(basename "$d")
    images=$(yq -o=json -I0 '[to_entries[] | select(.value | has("definition")) | .key]' "$manifest")
    pairs=$(jq -c --arg app "$app" --argjson imgs "$images" \
        '. + [($imgs[] | {app: $app, image: .})]' <<<"$pairs")
done

printf '%s' "$pairs"
