#!/usr/bin/env bash
# scripts/generate-compliance-artifacts — Extract and process compliance artifacts from a built image.
#
# Usage:
#   scripts/generate-compliance-artifacts --image <name>
#
# Expects the image to already be built and tagged as <registry>:dev.
# Produces: sbom.spdx.json, sbom.cdx.json, provenance.slsa.json,
#           secrets.json, and optionally vex.json
# in artifacts/<image>/.
#
# Caches the enriched CycloneDX SBOM keyed on SPDX content + tool versions.
# Cache hit skips the SPDX→CycloneDX conversion and sbomify enrichment steps.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
APP_MANIFEST="${REPO_ROOT}/apps/sbomify/app-images.yaml"
LOCKFILE="${REPO_ROOT}/common/tool-versions.lock.yaml"
ARTIFACTS="${REPO_ROOT}/artifacts"

usage() {
    echo "Usage: $0 --image NAME"
    exit 1
}

IMAGE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --image) IMAGE="$2"; shift 2 ;;
        *) echo "Unknown option: $1"; usage ;;
    esac
done

[[ -z "$IMAGE" ]] && usage

REG=$(yq -r ".\"${IMAGE}\".registry | select(. != null)" "$APP_MANIFEST")
[[ -z "$REG" ]] && { echo "ERROR: no registry found for image '${IMAGE}'" >&2; exit 1; }

OUT="${ARTIFACTS}/${IMAGE}"
mkdir -p "$OUT"

# ── Export image and extract build attestations ──────────────

echo ""
echo "=== Exporting image ==="
docker save "${REG}:dev" -o "${OUT}/image.tar"

echo ""
echo "=== Extracting build attestations ==="
tar -xf "${OUT}/image.tar" -C "${OUT}" index.json
manifest_list_digest=$(jq -r '.manifests[0].digest' "${OUT}/index.json" | cut -d: -f2)
tar -xf "${OUT}/image.tar" -C "${OUT}" "blobs/sha256/${manifest_list_digest}"
att_digest=$(jq -r '.manifests[] | select(.annotations["vnd.docker.reference.type"] == "attestation-manifest") | .digest' "${OUT}/blobs/sha256/${manifest_list_digest}" | cut -d: -f2)
tar -xf "${OUT}/image.tar" -C "${OUT}" "blobs/sha256/${att_digest}"

for layer in $(jq -r '.layers[] | @base64' "${OUT}/blobs/sha256/${att_digest}"); do
    predicate_type=$(echo "$layer" | base64 -d | jq -r '.annotations["in-toto.io/predicate-type"]')
    layer_digest=$(echo "$layer" | base64 -d | jq -r '.digest' | cut -d: -f2)
    tar -xf "${OUT}/image.tar" -C "${OUT}" "blobs/sha256/${layer_digest}"
    case "$predicate_type" in
        *spdx*)
            jq '.predicate' "${OUT}/blobs/sha256/${layer_digest}" > "${OUT}/sbom.spdx.json"
            pkg_count=$(jq '.packages | length' "${OUT}/sbom.spdx.json")
            echo "  SPDX SBOM: ${pkg_count} packages"
            ;;
        *provenance*)
            jq '.predicate' "${OUT}/blobs/sha256/${layer_digest}" > "${OUT}/provenance.slsa.json"
            echo "  SLSA provenance extracted"
            ;;
    esac
done

# Clean up temp blobs
rm -f "${OUT}/index.json"
rm -rf "${OUT}/blobs"

# ── Convert SPDX → CycloneDX ──────────────────────────────────

echo ""
echo "=== Converting SPDX → CycloneDX ==="
"${REPO_ROOT}/bin/sbom-convert" convert "${OUT}/sbom.spdx.json" -f cyclonedx -o "${OUT}/sbom.cdx.json"
cdx_components=$(jq '.components | length' "${OUT}/sbom.cdx.json")
cdx_deps=$(jq '.dependencies | length' "${OUT}/sbom.cdx.json")
echo "  CycloneDX SBOM: ${cdx_components} components, ${cdx_deps} dependencies"

# ── Enrich SBOM (with caching) ────────────────────────────────

echo ""
echo "=== Enriching SBOM ==="
result=$("${REPO_ROOT}/common/scripts/enrich-sbom.bash" "${OUT}/sbom.cdx.json" "${IMAGE}")
echo "  ${result}"

# ── Vulnerability scan (grype) ────────────────────────────────
#
# Runs against the enriched SBOM (which now carries an operating-system
# component — see enrich-sbom.bash), so `sbom:` lookup finds the distro
# without needing --distro. Output feeds the release-website via
# extract-release-data, which reads per-vulnerability descriptions and
# surfaces them in the matrix.
#
# Grype/jq failures (DB update glitch, transient network error, malformed
# SBOM) are tolerated: cves.json is best-effort enrichment, not a build
# input, and we don't want one flaky scan to abort the build.
echo ""
echo "=== Scanning SBOM for vulnerabilities ==="
# Print grype DB status so CI logs explain a missing/stale DB without us
# guessing. Stderr is shown unguarded — the previous 2>/dev/null swallowed
# the actual failure cause when grype hit a network/DB error in CI.
"${REPO_ROOT}/bin/grype" db status 2>&1 | sed 's/^/  /'
if "${REPO_ROOT}/bin/grype" sbom:"${OUT}/sbom.cdx.json" -o json --quiet \
        > "${OUT}/cves.json" \
   && jq -e empty "${OUT}/cves.json" >/dev/null 2>&1; then
    matches=$(jq '.matches | length' "${OUT}/cves.json")
    echo "  grype found ${matches} matches → ${OUT}/cves.json"
else
    echo "  (scan failed — cves.json missing or empty; matrix will fall back to no-description)"
    rm -f "${OUT}/cves.json"
fi

# ── VEX ───────────────────────────────────────────────────────
#
# Custom images carry a hand-authored OpenVEX JSON next to their DHI
# definition (common/images/<name>/<name>.vex.json or similar). We ship it
# as-is — consumers pass it straight to `grype --vex`.
vex_file=$(find "${REPO_ROOT}" -name "${IMAGE}.vex.json" -path "*/images/*" 2>/dev/null | head -1)
if [ -n "$vex_file" ]; then
    cp "$vex_file" "${OUT}/vex.json"
    echo "  copied VEX: ${vex_file}"
fi

echo ""
echo "=== Gitleaks secrets scan ==="
"${REPO_ROOT}/bin/gitleaks" detect --source="docker-archive:${OUT}/image.tar" \
    -f json -r "${OUT}/secrets.json" 2>/dev/null \
    && echo "  saved ${OUT}/secrets.json" || echo "  (no secrets found)"

echo ""
echo "=== Artifacts ==="
ls -lh "${OUT}/"
