#!/usr/bin/env bash
# scripts/tag-app-collection — Add an app-collection version tag to an image.
#
# Usage:
#   scripts/tag-app-collection \
#     --image <name> \
#     --component-tag <tag> \
#     --app-collection-version <version> \
#     --registry <registry>
#
# Requires: crane (via bin/crane)
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
  echo "Usage: $0 --image NAME --component-tag TAG --app-collection-version VERSION --registry REGISTRY"
  exit 1
}

IMAGE=""
COMPONENT_TAG=""
APP_COLLECTION_VERSION=""
REGISTRY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --image) IMAGE="$2"; shift 2 ;;
    --component-tag) COMPONENT_TAG="$2"; shift 2 ;;
    --app-collection-version) APP_COLLECTION_VERSION="$2"; shift 2 ;;
    --registry) REGISTRY="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$IMAGE" || -z "$COMPONENT_TAG" || -z "$APP_COLLECTION_VERSION" || -z "$REGISTRY" ]] && usage

echo "==> Resolving ${REGISTRY}:${COMPONENT_TAG}" >&2
DIGEST=$("${REPO_ROOT}/bin/crane" digest "${REGISTRY}:${COMPONENT_TAG}" 2>&1) || {
  echo "ERROR: crane digest failed: ${DIGEST}" >&2
  exit 1
}

echo "    Digest: ${DIGEST}" >&2
echo "    Adding app-collection tag: ${APP_COLLECTION_VERSION}" >&2

"${REPO_ROOT}/bin/crane" tag "${REGISTRY}@${DIGEST}" "${APP_COLLECTION_VERSION}"

echo "==> Tagged ${IMAGE} with ${APP_COLLECTION_VERSION}" >&2
