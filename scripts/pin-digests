#!/usr/bin/env bash
# Resolve current digests for all stock DHI images and update image-manifest.json
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
MANIFEST="${REPO_ROOT}/.github/image-manifest.json"

echo "Pinning stock DHI image digests..."

# For each stock image, resolve the digest via crane (using Justfile wrapper)
for row in $(jq -c '.stock[]' "$MANIFEST"); do
    name=$(echo "$row" | jq -r '.name')
    source=$(echo "$row" | jq -r '.source')

    echo -n "  ${name} (${source}): "
    digest=$(just --justfile "${REPO_ROOT}/Justfile" crane digest "$source" 2>/dev/null)
    echo "$digest"

    # Update the manifest in place
    jq --arg name "$name" --arg digest "$digest" \
        '(.stock[] | select(.name == $name)).digest = $digest' \
        "$MANIFEST" > "${MANIFEST}.tmp" && mv "${MANIFEST}.tmp" "$MANIFEST"
done

echo "Done. Digests written to ${MANIFEST}"
