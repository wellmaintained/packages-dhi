#!/usr/bin/env bash
# Wrapper for protobom/sbom-convert — downloads binary on first use.
# Unlike other bin/ tools, sbom-convert has no Docker image so we use
# a direct binary instead of the dhi-tools-shim.
set -euo pipefail

VERSION="0.0.7"
CHECKSUM="79e581fa36a0d05c1e29130494f1757672f5e12d209e9b6270b7b17b70fe6a58"

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/sbom-convert"
BINARY="${CACHE_DIR}/sbom-convert-${VERSION}"

if [ ! -x "$BINARY" ]; then
    mkdir -p "$CACHE_DIR"
    url="https://github.com/protobom/sbom-convert/releases/download/v${VERSION}/sbom-convert_linux_amd64.tar.gz"
    echo "sbom-convert: downloading v${VERSION}..." >&2
    tmpfile=$(mktemp)
    curl -sL "$url" -o "$tmpfile"
    actual=$(sha256sum "$tmpfile" | cut -d' ' -f1)
    if [ "$actual" != "$CHECKSUM" ]; then
        rm -f "$tmpfile"
        echo "sbom-convert: checksum mismatch (expected ${CHECKSUM}, got ${actual})" >&2
        exit 1
    fi
    tar -xzf "$tmpfile" -C "$CACHE_DIR" sbom-convert
    mv "$CACHE_DIR/sbom-convert" "$BINARY"
    chmod +x "$BINARY"
    rm -f "$tmpfile"
    echo "sbom-convert: installed v${VERSION} to ${BINARY}" >&2
fi

exec "$BINARY" "$@"
