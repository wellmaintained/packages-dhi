PATH_add bin

# Unified cache under XDG_CACHE_HOME — shared across worktrees, persisted in CI via sticky disk
export PACKAGES_DHI_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/packages-dhi"
export GRYPE_DB_CACHE_DIR="${PACKAGES_DHI_CACHE}/grype"
export UV_CACHE_DIR="${PACKAGES_DHI_CACHE}/uv"
export HUGO_CACHEDIR="${PACKAGES_DHI_CACHE}/hugo"
